  "entry": [
    {
      "resource": {
        "resourceType": "Questionnaire",
        "status": "active",
        "name": "hipaa-privacy-notice",
        "title": "HIPAA Notice of Privacy Practices",
        "description": "Acknowledgement confirming receipt of HIPAA Privacy Notice from Wider Circle.",
        "item": [
          {
            "linkId": "contact-group",
            "text": "Contact Information",
            "type": "group",
            "item": [
              { "linkId": "first-name", "text": "First Name", "type": "string", "required": true },
              { "linkId": "last-name", "text": "Last Name", "type": "string", "required": true },
              { "linkId": "email", "text": "Email Address", "type": "string", "required": true },
              { "linkId": "phone", "text": "Phone Number", "type": "string", "required": true }
            ]
          },
          {
            "linkId": "hipaa-notice",
            "text": "HIPAA NOTICE OF PRIVACY PRACTICES\n\nThis notice outlines your protected health information, how it may be used, and what your rights are. Please review carefully and ask any questions prior to signing. Questions about this notice can be directed to Wider Circle.\n\nWe, Wider Circle, understand that protected health information about you and your health is personal. We are committed to protecting health information about you. This Notice applies to all of the records of your care generated by Wider Circle.\n\nThe law requires us to: make sure that protected health information that identifies you is kept private; notify you about how we protect health information about you; explain how, when and why we use and disclose health information; follow the terms of the Notice that is currently in effect.",
            "type": "display"
          },
          {
            "linkId": "agree-hipaa",
            "text": "I hereby agree to the document above.",
            "type": "boolean",
            "required": true
          },
          {
            "linkId": "signature",
            "text": "Signature",
            "type": "string",
            "required": true,
            "extension": [
              {
                "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
                "valueCodeableConcept": {
                  "coding": [{ "system": "http://hl7.org/fhir/questionnaire-item-control", "code": "text-box" }]
                }
              }
            ]
          },
          {
            "linkId": "parent-guardian",
            "text": "Parent/Guardian Name (if client is under 18)",
            "type": "string",
            "required": false
          }
        ]
      },
      "request": { "method": "POST", "url": "Questionnaire", "ifNoneExist": "name=hipaa-privacy-notice" }
    },
    {
      "resource": {
        "resourceType": "Questionnaire",
        "status": "active",
        "name": "telehealth-consent",
        "title": "Telehealth Consent",
        "description": "Consent to receive healthcare services via telehealth from Wider Circle.",
        "item": [
          {
            "linkId": "contact-group",
            "text": "Contact Information",
            "type": "group",
            "item": [
              { "linkId": "first-name", "text": "First Name", "type": "string", "required": true },
              { "linkId": "last-name", "text": "Last Name", "type": "string", "required": true },
              { "linkId": "email", "text": "Email Address", "type": "string", "required": true },
              { "linkId": "phone", "text": "Phone Number", "type": "string", "required": true }
            ]
          },
          {
            "linkId": "telehealth-agreement",
            "text": "TELEHEALTH AGREEMENT\n\nI understand that my health and wellness provider Wider Circle, wishes me to have a telehealth consultation. This means that through an interactive video connection, I will be able to consult with the above-named provider about my health and wellness concerns. My provider has explained to me how telehealth will be used to do such consultation and how else we will use telehealth to connect while working together, using the Healthie telehealth platform.\n\nI understand there are potential risks with this technology:\n- The video connection may not work or it may stop working during the consultation.\n- The video picture or information transmitted may not be clear enough to be useful for the consultation.\n\nThe benefits of a telehealth consultation are:\n- I do not need to travel to the consult location.\n- I have access to a specialist through this consultation.",
            "type": "display"
          },
          {
            "linkId": "agree-telehealth",
            "text": "I hereby agree to the document above.",
            "type": "boolean",
            "required": true
          },
          {
            "linkId": "patient-name-group",
            "text": "Patient Name",
            "type": "group",
            "item": [
              { "linkId": "patient-first", "text": "First Name", "type": "string" },
              { "linkId": "patient-last", "text": "Last Name", "type": "string" }
            ]
          },
          {
            "linkId": "parent-guardian",
            "text": "Parent/Guardian Name (if client is under 18)",
            "type": "string",
            "required": false
          },
          {
            "linkId": "signature",
            "text": "Signature",
            "type": "string",
            "required": true
          },
          {
            "linkId": "sign-date",
            "text": "Date",
            "type": "date",
            "required": true
          }
        ]
      },
      "request": { "method": "POST", "url": "Questionnaire", "ifNoneExist": "name=telehealth-consent" }
    },
